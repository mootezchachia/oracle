{
  "buildCommand": "cd oracle-dashboard && npm install && npm run build",
  "outputDirectory": "oracle-dashboard/dist",
  "framework": null,
  "rewrites": [],
  "crons": [
    {
      "path": "/api/strategy100-run",
      "schedule": "*/15 * * * *"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, OPTIONS" }
      ]
    }
  ]
}
